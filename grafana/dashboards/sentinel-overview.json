{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Sentinel AI Governance Platform — Real-time operational overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "type": "stat",
      "title": "Total Requests (1h)",
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "expr": "sum(increase(sentinel_requests_total[1h]))",
        "legendFormat": "Requests"
      }]
    },

    {
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "type": "stat",
      "title": "Block Rate (5m)",
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.3 }
          ]
        }
      },
      "targets": [{
        "expr": "sum(rate(sentinel_requests_total{verdict=\"blocked\"}[5m])) / sum(rate(sentinel_requests_total[5m]))",
        "legendFormat": "Block Rate"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },

    {
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "type": "stat",
      "title": "Fast Path p95 Latency",
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.015 },
            { "color": "red", "value": 0.05 }
          ]
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(sentinel_request_duration_seconds_bucket{path=\"fast_path\"}[5m])) by (le))",
        "legendFormat": "p95 fast_path"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "type": "stat",
      "title": "Cognitive Path p95 Latency",
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 2.0 }
          ]
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(sentinel_request_duration_seconds_bucket{path=\"cognitive_path\"}[5m])) by (le))",
        "legendFormat": "p95 cognitive_path"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "type": "stat",
      "title": "Circuit Breaker (Ollama)",
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 },
            { "color": "yellow", "value": 2 }
          ]
        }
      },
      "targets": [{
        "expr": "sentinel_circuit_breaker_state{service=\"ollama\"}",
        "legendFormat": "0=CLOSED 1=OPEN 2=HALF_OPEN"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED" }, "1": { "text": "OPEN" }, "2": { "text": "HALF_OPEN" } } }
          ]
        }
      }
    },

    {
      "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "type": "stat",
      "title": "Audit DLQ Depth",
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 100 }
          ]
        }
      },
      "targets": [{
        "expr": "sentinel_audit_dlq_depth",
        "legendFormat": "DLQ"
      }]
    },

    {
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "type": "timeseries",
      "title": "Request Rate by Verdict",
      "datasource": "Prometheus",
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "allowed" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "human_review" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FFB357", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "sum(rate(sentinel_requests_total{verdict=\"allowed\"}[1m])) by (verdict)", "legendFormat": "allowed" },
        { "expr": "sum(rate(sentinel_requests_total{verdict=\"blocked\"}[1m])) by (verdict)", "legendFormat": "blocked" },
        { "expr": "sum(rate(sentinel_requests_total{verdict=\"human_review\"}[1m])) by (verdict)", "legendFormat": "human_review" }
      ]
    },

    {
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "type": "timeseries",
      "title": "Request Latency Percentiles",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(sentinel_request_duration_seconds_bucket{path=\"fast_path\"}[5m])) by (le))", "legendFormat": "fast_path p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(sentinel_request_duration_seconds_bucket{path=\"fast_path\"}[5m])) by (le))", "legendFormat": "fast_path p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(sentinel_request_duration_seconds_bucket{path=\"fast_path\"}[5m])) by (le))", "legendFormat": "fast_path p99" },
        { "expr": "histogram_quantile(0.50, sum(rate(sentinel_request_duration_seconds_bucket{path=\"cognitive_path\"}[5m])) by (le))", "legendFormat": "cognitive p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(sentinel_request_duration_seconds_bucket{path=\"cognitive_path\"}[5m])) by (le))", "legendFormat": "cognitive p95" }
      ]
    },

    {
      "id": 20,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "type": "timeseries",
      "title": "Judge Calls by Tier & Outcome",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(sentinel_judge_calls_total[1m])) by (tier, outcome)", "legendFormat": "tier{{tier}} {{outcome}}" }
      ]
    },

    {
      "id": 21,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "type": "timeseries",
      "title": "Rate Limit Hits by Agent",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(sentinel_rate_limit_hits_total[1m])) by (agent_id)", "legendFormat": "{{agent_id}}" }
      ]
    },

    {
      "id": 30,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "type": "timeseries",
      "title": "Top 10 Tools by Volume",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "topk(10, sum(rate(sentinel_requests_total[5m])) by (tool_name))",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },

    {
      "id": 31,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "type": "timeseries",
      "title": "Active WebSocket Connections",
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sentinel_websocket_connections_active", "legendFormat": "Active connections" }
      ]
    },

    {
      "id": 40,
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 28 },
      "type": "table",
      "title": "Active Policy Versions",
      "datasource": "Prometheus",
      "options": { "sortBy": [{ "displayName": "policy_group", "desc": false }] },
      "targets": [
        {
          "expr": "sentinel_policy_version_active == 1",
          "legendFormat": "{{policy_group}} / {{version}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "policy_group": "Policy Group", "version": "Active Version" } } }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["sentinel", "ai-governance"],
  "templating": {
    "list": [
      {
        "name": "agent_id",
        "type": "query",
        "datasource": "Prometheus",
        "definition": "label_values(sentinel_requests_total, agent_id)",
        "query": "label_values(sentinel_requests_total, agent_id)",
        "includeAll": true,
        "multi": true,
        "label": "Agent"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Sentinel — Overview",
  "uid": "sentinel-overview-v1",
  "version": 1
}
