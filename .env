# =============================================================================
# Sentinel AI — Environment Configuration
# =============================================================================

# Gateway
SENTINEL_ADMIN_KEY=snl_admin_dev_changeme_replace_me
GATEWAY_ENV=development
GATEWAY_LOG_LEVEL=INFO

# JWT (paths to certs generated in ./certs/)
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem

# Redis (Docker runs on localhost:6379 — no changes needed)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Neo4j (matches docker-compose.dev.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel_dev_password
NEO4J_DATABASE=sentinel

# Ollama (local LLM Judge Tier 1 — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=3

# ⚠️  OPTIONAL — Anthropic (Claude fallback, Judge Tier 3)
# Leave blank to skip Claude and only use Ollama
ANTHROPIC_API_KEY=

# ⚠️  OPTIONAL — Langfuse (LLM observability UI at :3001)
# Leave blank to disable tracing
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
